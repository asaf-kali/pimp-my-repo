    "version": "0.2.0",
    "configurations": [
        {
            "name": "PMR tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "console": "integratedTerminal",
            "args": [
                "."
            ]
        },
        {
            "name": "PMR: debug django",
            "type": "debugpy",
            "request": "launch",
            "program": "pimp_my_repo/cli/main.py",
            "console": "integratedTerminal",
            "args": [
                "-p",
                "~/pmr/django"
            ]
        }
    ]
}
